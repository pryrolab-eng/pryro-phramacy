# =============================================================================
# Pryrox — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your .env file to version control.
# See docs/environment-variables.md for full descriptions of each variable.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase
# Required for all database, authentication, and realtime functionality.
# Find these values in your Supabase project dashboard under Settings > API.
# -----------------------------------------------------------------------------

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase anonymous/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key — SERVER ONLY, never expose to the browser
# This key bypasses Row Level Security. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here


# -----------------------------------------------------------------------------
# Application
# Base URL of the running application. Used in KPay callback URLs and
# internal server-to-server fetch calls.
# -----------------------------------------------------------------------------

# Public base URL of the application (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal base URL used by some API routes (typically the same as APP_URL)
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# KPay Payment Gateway
# Credentials for the KPay mobile money / card payment integration.
# Obtain these from your KPay merchant account at pay.esicia.com.
# -----------------------------------------------------------------------------

# KPay API base URL (default: https://pay.esicia.com)
KPAY_BASE_URL=https://pay.esicia.com

# KPay merchant username
KPAY_USERNAME=your-kpay-username

# KPay merchant password
KPAY_PASSWORD=your-kpay-password

# KPay retailer identifier assigned to your merchant account
KPAY_RETAILER_ID=your-kpay-retailer-id

# (Optional) Webhook URL for KPay payment callbacks
# Defaults to: ${NEXT_PUBLIC_APP_URL}/api/kpay/webhook
KPAY_RETURN_URL=https://your-app.example.com/api/kpay/webhook

# (Optional) URL to redirect the customer after a successful payment
# Defaults to: ${NEXT_PUBLIC_APP_URL}/payment/success
KPAY_REDIRECT_URL=https://your-app.example.com/payment/success
